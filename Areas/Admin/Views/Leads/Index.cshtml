@model IReadOnlyList<AdminLeadRequestViewModel>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Заявки";
}

<section class="admin-page-head">
    <div>
        <p class="eyebrow">Обращения клиентов</p>
        <h1 class="admin-title">Заявки</h1>
        <p class="admin-muted">Здесь отображаются заявки, отправленные через формы сайта.</p>
    </div>
    <a class="admin-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Назад к разделам</a>
</section>

<section class="admin-panel">
    @if (Model.Count == 0)
    {
        <p class="admin-muted">Заявок пока нет.</p>
    }
    else
    {
        <div class="admin-lead-list">
            @foreach (var lead in Model)
            {
                <article class="admin-lead-row">
                    <div>
                        <h2>@lead.Name</h2>
                        <p><a href="tel:@lead.Phone">@lead.Phone</a></p>
                        @if (!string.IsNullOrWhiteSpace(lead.Message))
                        {
                            <p>@lead.Message</p>
                        }
                    </div>
                    <div class="admin-lead-row__meta">
                        <span>@lead.SourcePageSlug</span>
                        <time datetime="@lead.CreatedAtUtc.ToString("O")">@lead.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</time>
                    </div>
                </article>
            }
        </div>
    }
</section>
