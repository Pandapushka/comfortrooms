@model AdminPageContentViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = $"Тексты: {Model.PageTitle}";
}

<section class="admin-page-head">
    <div>
        <p class="eyebrow">Текстовый контент</p>
        <h1 class="admin-title">@Model.PageTitle</h1>
        <p class="admin-muted">Редактируйте заголовки, подзаголовки и короткие текстовые блоки страницы.</p>
    </div>
    <a class="admin-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Назад к разделам</a>
</section>

<section class="admin-panel">
    @if (Model.Groups.Count == 0)
    {
        <p class="admin-muted">Для этой страницы пока нет текстовых блоков.</p>
    }
    else
    {
        <form asp-area="Admin" asp-controller="Content" asp-action="UpdateAll" asp-route-slug="@Model.PageSlug" method="post" class="admin-content-list">
            @Html.AntiForgeryToken()
            @foreach (var group in Model.Groups)
            {
                <section class="admin-content-group">
                    <div class="admin-content-group__head">
                        <div>
                            <h2>@group.Title</h2>
                            @if (!string.IsNullOrWhiteSpace(group.Description))
                            {
                                <p>@group.Description</p>
                            }
                        </div>
                        @if (group.BackgroundBlock is not null)
                        {
                            <label class="admin-field admin-field--compact">
                                <span>@group.BackgroundBlock.Label</span>
                                <select name="values[@group.BackgroundBlock.Id]">
                                    @foreach (var option in group.BackgroundBlock.Options)
                                    {
                                        <option value="@option.Value" selected="@(string.Equals(group.BackgroundBlock.Value, option.Value, StringComparison.OrdinalIgnoreCase))">@option.Label</option>
                                    }
                                </select>
                            </label>
                        }
                    </div>

                    <div class="admin-content-group__items">
                        @foreach (var item in group.Items)
                        {
                            <div class="admin-content-row">
                                <div class="admin-content-row__label">
                                    <h3>@item.TextBlock.Label</h3>
                                    <p>@item.TextBlock.Key</p>
                                </div>
                                <div class="admin-content-row__controls">
                                    <label class="admin-field">
                                        <span>Текст</span>
                                        <textarea name="values[@item.TextBlock.Id]" rows="3">@Html.Raw(item.TextBlock.Value)</textarea>
                                    </label>

                                    @if (item.ColorBlock is not null)
                                    {
                                        <label class="admin-field">
                                            <span>Цвет этого текста</span>
                                            <select name="values[@item.ColorBlock.Id]">
                                                @foreach (var option in item.ColorBlock.Options)
                                                {
                                                    <option value="@option.Value" selected="@(string.Equals(item.ColorBlock.Value, option.Value, StringComparison.OrdinalIgnoreCase))">@option.Label</option>
                                                }
                                            </select>
                                        </label>
                                    }

                                    @if (item.StyleBlock is not null)
                                    {
                                        <label class="admin-field">
                                            <span>Цвет кнопки</span>
                                            <select name="values[@item.StyleBlock.Id]">
                                                @foreach (var option in item.StyleBlock.Options)
                                                {
                                                    <option value="@option.Value" selected="@(string.Equals(item.StyleBlock.Value, option.Value, StringComparison.OrdinalIgnoreCase))">@option.Label</option>
                                                }
                                            </select>
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
            <button class="admin-button admin-button--primary" type="submit">Сохранить все тексты</button>
        </form>
    }
</section>
