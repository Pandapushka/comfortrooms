<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Comfort Rooms</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ComfortRooms.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid public-nav">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Comfort <span>Rooms</span></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Сотрудничество</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/sotrudnichestvo">Все направления</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/sotrudnichestvo/na-zakaz">Изготовление под заказ</a></li>
                                <li><a class="dropdown-item" href="/sotrudnichestvo/opt">Оптовым партнерам</a></li>
                                <li><a class="dropdown-item" href="/sotrudnichestvo/roznitsa">Розничным клиентам</a></li>
                                <li><a class="dropdown-item" href="/sotrudnichestvo/dizayneram">Дизайнерам</a></li>
                                <li><a class="dropdown-item" href="/sotrudnichestvo/magazinam">Магазинам</a></li>
                                <li><a class="dropdown-item" href="/sotrudnichestvo/internet-magazinam">Интернет-магазинам</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/o-kompanii">О компании</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/kontakty">Контакты</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="https://comfortrooms.ru/shop/" target="_blank" rel="noopener">Интернет-магазин</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link public-nav__admin" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Админка</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Comfort Rooms - <a asp-area="" asp-controller="Home" asp-action="About">О компании</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
