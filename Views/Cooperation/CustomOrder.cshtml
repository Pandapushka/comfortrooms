@model ComfortRooms.ViewModels.CustomOrderPageViewModel
@{
    Layout = null;
    var galleryImages = Model.GalleryImages.ToList();
    var heroImage = galleryImages.FirstOrDefault()?.ImageUrl ?? "/images/fallbacks/luxury-chandelier-interior.png";
    string Text(string key, string fallback) => Model.TextBlocks.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value) ? value : fallback;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.HeroTitle | Comfort Rooms</title>
    <link rel="stylesheet" href="~/css/custom-order.css" asp-append-version="true">
</head>
<body>
    <nav class="co-nav">
        <a href="/" class="co-brand">Comfort <span>Rooms</span></a>
        <button type="button" class="co-menu-button" data-menu-toggle aria-controls="mobile-menu" aria-expanded="false">Меню</button>
        <div class="co-nav__links" id="mobile-menu">
            <a href="#process">Как мы работаем</a>
            <a href="#contract">Этапы договора</a>
            <a href="#materials">Материалы</a>
            <a href="#portfolio">Наши работы</a>
            <a class="co-nav__cta" href="#contact">Оставить заявку</a>
        </div>
    </nav>

    <section class="co-hero">
        <div class="co-hero__image">
            <img src="@heroImage" alt="Индивидуальная люстра Comfort Rooms">
        </div>
        <div class="co-hero__content">
            <p class="co-eyebrow">Сотрудничество — изготовление под заказ</p>
            <h1>@Model.HeroTitle</h1>
            <p>@Model.HeroDescription</p>
            <div class="co-actions">
                <a class="co-button co-button--primary" href="#contact">Оставить заявку на просчет</a>
                <a class="co-button co-button--secondary" href="#portfolio">Смотреть работы</a>
            </div>
        </div>
    </section>

    <section class="co-intro">
        <div>
            <p class="co-eyebrow">Индивидуальное производство</p>
            <h2>@Text("intro-title", "Ваш проект требует особого решения?")</h2>
            <p>@Text("intro-description", "Стандартные люстры не подходят к уникальному интерьеру? Мы специализируемся на производстве люстр и светильников на заказ любой сложности. Мы воплощаем в жизнь самые смелые идеи: от чертежей дизайнера до вашей фотографии или эскиза.")</p>
            <blockquote>@Text("intro-accent", "Наше призвание — создавать не просто освещение, а арт-объекты, которые становятся смысловым центром пространства.")</blockquote>
        </div>
    </section>

    <section id="process" class="co-section co-section--warm">
        <div class="co-section__head">
            <p class="co-eyebrow">Процесс</p>
            <h2>@Text("process-title", "Как мы работаем?")</h2>
        </div>
        <div class="co-card-grid">
            <article><span>01</span><h3>Заявка и эскиз</h3><p>Вы отправляете техническое задание, чертеж, фото, референс или набросок от руки.</p></article>
            <article><span>02</span><h3>3D-модель и расчет</h3><p>Мы уточняем размеры, конструктив, материалы, покрытие и готовим ориентир по стоимости.</p></article>
            <article><span>03</span><h3>Договор и предоплата</h3><p>Фиксируем состав работ, сроки, стоимость, порядок согласований и запускаем производство.</p></article>
            <article><span>04</span><h3>Производство и контроль</h3><p>Ведем изделие в работе, отправляем фото или видео процесса и согласуем важные этапы.</p></article>
            <article><span>05</span><h3>Доставка на объект</h3><p>После финальной оплаты аккуратно передаем светильник на объект и закрывающие документы.</p></article>
            <article><span>06</span><h3>Поддержка дизайнера</h3><p>При проектной работе учитываем агентские условия и документы для дизайнерского сопровождения.</p></article>
        </div>
    </section>

    <section id="contract" class="co-split">
        <div>
            <p class="co-eyebrow">Документы</p>
            <h2>@Text("contract-title", "Этапы договора и согласований")</h2>
            <p>@Text("contract-description", "Процесс строится так, чтобы заказчик, дизайнер и производство одинаково понимали сроки, ответственность и результат.")</p>
            <a class="co-button co-button--secondary" href="/downloads/comfort-rooms-presentation.pdf">Скачать презентацию</a>
        </div>
        <ol class="co-steps">
            <li><span>Просчет</span>Получаем вводные, считаем изделие и согласуем коммерческие условия.</li>
            <li><span>Чертежи</span>Утверждаем размеры, крепление, материалы, покрытие и технический конструктив.</li>
            <li><span>Производство</span>Запускаем работу после договора и предоплаты, показываем промежуточный результат.</li>
            <li><span>Передача</span>Организуем доплату, доставку, акты приема-передачи и дальнейшее сопровождение.</li>
        </ol>
    </section>

    <section id="materials" class="co-section">
        <div class="co-section__head">
            <p class="co-eyebrow">Материалы и покрытия</p>
            <h2>@Text("materials-title", "Светильник под интерьер, а не наоборот")</h2>
        </div>
        <div class="co-feature-grid">
            <article><h3>Металл</h3><p>Сталь, латунь, бронза и декоративные металлические элементы под задачу проекта.</p></article>
            <article><h3>Стекло и хрусталь</h3><p>Подбираем прозрачность, форму, фактуру и характер свечения для нужного эффекта.</p></article>
            <article><h3>Покрытия RAL</h3><p>Согласуем цвет, блеск, патину и сложные финиши под палитру интерьера.</p></article>
            <article><h3>3D-моделирование</h3><p>Помогаем увидеть пропорции изделия до производства и проверить идею технически.</p></article>
        </div>
    </section>

    <section id="why-us" class="co-split co-split--image">
        <div>
            <p class="co-eyebrow">Преимущества</p>
            <h2>@Text("why-title", "Почему выбирают нас?")</h2>
            <div class="co-list">
                <p><strong>Полный цикл.</strong> От идеи, референса и чертежа до производства, доставки и документов.</p>
                <p><strong>Проектная аккуратность.</strong> Учитываем масштаб интерьера, монтаж, материалы и эксплуатацию.</p>
                <p><strong>Прозрачность.</strong> Фиксируем этапы, показываем процесс и держим коммуникацию понятной.</p>
                <p><strong>Официальная работа.</strong> Договор, закрывающие документы и условия для дизайнеров.</p>
            </div>
        </div>
        <img src="@heroImage" alt="Производство люстр Comfort Rooms">
    </section>

    <section id="portfolio" class="co-section co-section--warm">
        <div class="co-section__head co-section__head--center">
            <p class="co-eyebrow">Портфолио</p>
            <h2>@Text("portfolio-title", "Наши работы")</h2>
            <p>@Text("portfolio-description", "Листайте, чтобы увидеть больше")</p>
        </div>

        <div class="co-carousel">
            <button id="prevBtn" class="co-carousel__button co-carousel__button--prev" type="button" aria-label="Предыдущий слайд">‹</button>
            <div class="co-carousel__viewport">
                <div id="carouselTrack" class="carousel-track">
                    @foreach (var image in galleryImages)
                    {
                        <div class="carousel-slide">
                            <img src="@image.ImageUrl" alt="@(image.AltText ?? image.Title)">
                            <span>@image.Title</span>
                        </div>
                    }
                </div>
            </div>
            <button id="nextBtn" class="co-carousel__button co-carousel__button--next" type="button" aria-label="Следующий слайд">›</button>
        </div>

        <div class="co-dots">
            @for (var index = 0; index < galleryImages.Count; index++)
            {
                <button class="dot @(index == 0 ? "is-active" : "")" data-index="@index" type="button" aria-label="Слайд @(index + 1)"></button>
            }
        </div>
    </section>

    <section id="contact" class="co-contact">
        <div>
            <p class="co-eyebrow">Заявка</p>
            <h2>@Text("contact-title", "Изготовить светильник?")</h2>
            <p>@Text("contact-description", "Хотите эксклюзивный светильник или воссоздать люстру по картинке или чертежу? Тогда смело оставляйте заявку!")</p>
            <div class="co-contact__links">
                <a href="tel:84951203090">8 (495) 120-30-90</a>
                <a href="mailto:sales@comfortrooms.ru">sales@comfortrooms.ru</a>
                <address>117342, Москва, ул. Бутлерова 17, БЦ NEO GEO, офис 4056</address>
            </div>
        </div>

        <div class="co-form-card">
            @if (TempData["LeadRequestSuccess"] is string successMessage)
            {
                <div class="co-alert">@successMessage</div>
            }

            <form asp-controller="Cooperation" asp-action="CustomOrderLead" method="post" id="contactForm" class="co-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="co-validation"></div>
                <label>
                    <span>Ваше имя</span>
                    <input asp-for="LeadRequest.Name" required placeholder="Иван Иванов">
                    <span asp-validation-for="LeadRequest.Name" class="co-validation"></span>
                </label>
                <label>
                    <span>Телефон</span>
                    <input asp-for="LeadRequest.Phone" type="tel" required placeholder="+7 (999) 000-00-00">
                    <span asp-validation-for="LeadRequest.Phone" class="co-validation"></span>
                </label>
                <label>
                    <span>Комментарий или описание задачи</span>
                    <textarea asp-for="LeadRequest.Message" rows="4" placeholder="Опишите желаемый светильник..."></textarea>
                    <span asp-validation-for="LeadRequest.Message" class="co-validation"></span>
                </label>
                <button type="submit" class="co-button co-button--primary">Получить просчет светильника</button>
                <p class="co-form__note">Нажимая кнопку, вы соглашаетесь с политикой обработки персональных данных.</p>
            </form>
        </div>
    </section>

    <footer class="co-footer">
        <span class="co-brand">Comfort <span>Rooms</span></span>
        <p>© 2026 Comfort Rooms. Все права защищены.</p>
    </footer>

    <script src="~/js/custom-order.js" asp-append-version="true"></script>
</body>
</html>
