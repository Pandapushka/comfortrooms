@model ContactsPageViewModel
@{
    ViewData["Title"] = Model.HeroTitle;
    string Text(string key, string fallback) => Model.TextBlocks.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value) ? value : fallback;
}

<section class="contacts-hero">
    <div>
        <p class="eyebrow">Связаться с нами</p>
        <h1>@Model.HeroTitle</h1>
        <p>@Model.HeroDescription Оставьте заявку, позвоните или напишите нам напрямую.</p>
    </div>
    <div class="contacts-card">
        <span>Comfort Rooms</span>
        <a href="tel:84951203090">8 (495) 120-30-90</a>
        <a href="mailto:sales@comfortrooms.ru">sales@comfortrooms.ru</a>
        <address>
            117342, город Москва,<br>
            Ул. Бутлерова 17, БЦ NEO GEO,<br>
            4-й этаж, офис 4056
        </address>
    </div>
</section>

<section class="contacts-section">
    <div class="contacts-info-grid">
        <article>
            <span>01</span>
            <h2>Индивидуальные изделия</h2>
            <p>Примем чертеж, фото, эскиз или описание задачи и подготовим следующий шаг для расчета.</p>
        </article>
        <article>
            <span>02</span>
            <h2>Партнерство</h2>
            <p>Работаем с дизайнерами, салонами, магазинами и e-commerce проектами.</p>
        </article>
        <article>
            <span>03</span>
            <h2>Проектная поддержка</h2>
            <p>Помогаем согласовать геометрию, материалы, покрытие и визуальную задачу светильника.</p>
        </article>
    </div>
</section>

<section class="contacts-directory">
    <div class="contacts-directory__head">
        <p class="eyebrow">Справочная информация</p>
        <h2>Офис, склад, бренды и материалы</h2>
    </div>
    <div class="contacts-directory__grid">
        <article>
            <h3>Офис</h3>
            <p>ООО «КОМФОРТ РУМС»</p>
            <p>117342, Москва, ул. Бутлерова 17, БЦ NEO GEO, офис 4056</p>
            <a href="mailto:sales@comfortrooms.ru">sales@comfortrooms.ru</a>
        </article>
        <article>
            <h3>Склад</h3>
            <p>Балашиха, Новомилетское шоссе, владение 3Б, склад 7.</p>
            <p>Отгрузка: понедельник-пятница, 10:00-17:00.</p>
            <a href="mailto:service@comfortrooms.ru">service@comfortrooms.ru</a>
        </article>
        <article>
            <h3>Направления связи</h3>
            <p>Продажи и партнерство: sales@comfortrooms.ru</p>
            <p>Дизайнеры и проекты: design@comfortrooms.ru</p>
            <p>Сервис и документы: service@comfortrooms.ru</p>
        </article>
        <article>
            <h3>Бренды и каталоги</h3>
            <p>iledex.ru, ilamp-world.com, arthomedecor.ru, belfasteon.ru.</p>
            <p>PDF-каталоги и ссылки на остатки нужно подключить как управляемые материалы.</p>
        </article>
    </div>
    <div class="contacts-map">
        <span>Карта</span>
        <p>Здесь будет подключена интерактивная карта офиса и схема проезда без потери скорости загрузки страницы.</p>
    </div>
</section>

<section id="contact-form" class="contacts-form-section">
    <div>
        <p class="eyebrow">Заявка</p>
        <h2>@Text("form-title", "Расскажите о задаче")</h2>
        <p>@Text("form-description", "Форма сохранит обращение в админ-панели. Менеджер сможет увидеть заявку в разделе «Заявки».")</p>
    </div>

    <div class="contacts-form-card">
        @if (TempData["LeadRequestSuccess"] is string successMessage)
        {
            <div class="admin-alert admin-alert--success">@successMessage</div>
        }

        <form asp-controller="Pages" asp-action="Contacts" method="post" class="contacts-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label class="admin-field">
                <span>Ваше имя</span>
                <input asp-for="LeadRequest.Name" placeholder="Иван Иванов" />
                <span asp-validation-for="LeadRequest.Name" class="text-danger"></span>
            </label>

            <label class="admin-field">
                <span>Телефон</span>
                <input asp-for="LeadRequest.Phone" type="tel" placeholder="+7 (999) 000-00-00" />
                <span asp-validation-for="LeadRequest.Phone" class="text-danger"></span>
            </label>

            <label class="admin-field">
                <span>Комментарий</span>
                <textarea asp-for="LeadRequest.Message" rows="5" placeholder="Опишите задачу, сроки или объект"></textarea>
                <span asp-validation-for="LeadRequest.Message" class="text-danger"></span>
            </label>

            <button class="admin-button admin-button--primary" type="submit">Отправить заявку</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
