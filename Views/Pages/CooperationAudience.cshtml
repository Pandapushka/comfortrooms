@model CooperationAudiencePageViewModel
@{
    ViewData["Title"] = Model.Title;
    string Text(string key, string fallback) => Model.TextBlocks.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value) ? value : fallback;
}

<section class="audience-hero">
    <div>
        <p class="eyebrow">@Model.Eyebrow</p>
        <h1>@Model.Title</h1>
        <p>@Model.Description</p>
        <div class="simple-hero__accent">@Model.Accent</div>
        <div class="simple-hero__actions">
            <a class="button button--primary" href="/kontakty#contact-form">Оставить заявку</a>
            <a class="button button--secondary" href="/sotrudnichestvo/na-zakaz">Изготовление под заказ</a>
        </div>
    </div>
    <div class="audience-hero__image">
        <img src="@Model.ImageUrl" alt="@Model.ImageAlt">
    </div>
</section>

<section class="audience-section audience-section--white">
    <div class="audience-section__head">
        <p class="eyebrow">Возможности</p>
        <h2>@Text("help-title", "Как мы помогаем")</h2>
    </div>
    <div class="audience-card-grid">
        @foreach (var card in Model.Cards)
        {
            <article>
                <span>@card.Number</span>
                <h3>@card.Title</h3>
                <p>@card.Description</p>
            </article>
        }
    </div>
</section>

<section class="audience-process">
    <div>
        <p class="eyebrow">Порядок работы</p>
        <h2>@Text("process-title", "Прозрачный процесс")</h2>
        <p>@Text("process-description", "Фиксируем вводные, согласовываем ожидания и ведем задачу до понятного результата.")</p>
    </div>
    <ol>
        @foreach (var step in Model.Steps)
        {
            <li>@step</li>
        }
    </ol>
</section>

<section class="audience-details">
    @if (Model.PageSlug == ComfortRooms.Services.PageSlugs.Cooperation)
    {
        <article>
            <h2>Все форматы в одном месте</h2>
            <p>Опт, розница, изготовление под заказ, e-commerce, дизайнеры и магазины теперь доступны как единый обзорный раздел, а не только как отдельные страницы.</p>
        </article>
        <article>
            <h2>Практический следующий шаг</h2>
            <p>Для каждого направления нужен свой набор материалов: прайс, остатки, договор, презентация, каталоги или заявка на расчет.</p>
        </article>
    }
    else if (Model.PageSlug == ComfortRooms.Services.PageSlugs.Wholesale)
    {
        <article>
            <h2>Условия для опта</h2>
            <p>Высокая маржинальность, бесплатная доставка, отсрочки и рассрочки, возможность эксклюзивного договора на регион.</p>
        </article>
        <article>
            <h2>Прайс и остатки</h2>
            <p>Следующий шаг для админки: управляемые ссылки на складские остатки, МРЦ и документы для партнеров.</p>
        </article>
    }
    else if (Model.PageSlug == ComfortRooms.Services.PageSlugs.Retail)
    {
        <article>
            <h2>Где купить</h2>
            <p>Для розницы нужен справочник магазинов с городами, адресами, партнерами и ссылками на online/offline покупку.</p>
        </article>
        <article>
            <h2>Подбор и монтаж</h2>
            <p>Покупателю важны консультация по ассортименту, встреча в магазине, доставка, монтаж и понятный контакт.</p>
        </article>
    }
    else if (Model.PageSlug == ComfortRooms.Services.PageSlugs.Designers)
    {
        <article>
            <h2>Дизайнерские условия</h2>
            <p>Специальные условия, агентский договор, выплаты, акты приема-передачи и проектная коммуникация.</p>
        </article>
        <article>
            <h2>3D-модели и каталоги</h2>
            <p>Дизайнерам нужны 3D-модели, печатные и PDF-каталоги, материалы по брендам и контакт design@comfortrooms.ru.</p>
        </article>
    }
    else if (Model.PageSlug == ComfortRooms.Services.PageSlugs.Ecommerce)
    {
        <article>
            <h2>Контент для продаж</h2>
            <p>Карточки товаров, изображения, баннеры, маркетинговые материалы и готовый загрузочный файл для интернет-магазина.</p>
        </article>
        <article>
            <h2>XML и остатки</h2>
            <p>Нужны управляемые ссылки на XML-выгрузки по брендам, остатки, каталоги и совместные акции.</p>
        </article>
    }
    else
    {
        <article>
            <h2>Материалы для продаж</h2>
            <p>Магазинам нужны понятные условия, изображения, описания, демонстрационные материалы и поддержка нестандартных запросов.</p>
        </article>
        <article>
            <h2>Партнерское сопровождение</h2>
            <p>Comfort Rooms помогает салонам и магазинам работать с ассортиментом, клиентскими задачами и проектными заказами.</p>
        </article>
    }
</section>

<section class="home-cta">
    <p class="eyebrow">Comfort Rooms</p>
    <h2>@Text("cta-title", "Готовы обсудить сотрудничество?")</h2>
    <p>@Text("cta-description", "Расскажите о формате работы, объекте или канале продаж, а мы предложим следующий шаг.")</p>
    <a class="button button--primary" href="/kontakty#contact-form">Связаться</a>
</section>
