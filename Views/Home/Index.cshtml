@model HomePageViewModel
@{
    ViewData["Title"] = "Главная";
}

<section class="hero-section home-hero">
    <div class="hero-section__content">
        <p class="eyebrow @Model.HeroEyebrowColorClass">@Model.HeroEyebrow</p>
        <h1>@Model.HeroTitle</h1>
        <p>@Model.HeroDescription</p>
        <div class="simple-hero__actions">
            <a class="button @Model.HeroPrimaryButtonStyleClass" href="/sotrudnichestvo/na-zakaz">@Model.HeroPrimaryButtonText</a>
            <a class="button @Model.HeroSecondaryButtonStyleClass" href="/kontakty">@Model.HeroSecondaryButtonText</a>
        </div>
    </div>
    <div class="home-hero__media" aria-hidden="true">
        <img src="@Model.HeroImageUrl" alt="@Model.HeroImageAlt">
    </div>
</section>

<section class="home-section home-section--white">
    <div class="home-section__head">
        <p class="eyebrow">Цифры доверия</p>
        <h2>Основа для проектной и партнерской работы</h2>
    </div>
    <div class="home-stats-grid">
        <article><strong>2000+</strong><span>моделей света и декора в ассортиментной базе</span></article>
        <article><strong>3500+</strong><span>клиентов и партнеров в разных форматах работы</span></article>
        <article><strong>70+</strong><span>дизайнерских проектов с индивидуальными решениями</span></article>
        <article><strong>3200+</strong><span>отгрузок для объектов, магазинов и частных заказчиков</span></article>
    </div>
</section>

<section class="home-section home-section--white">
    <div class="home-section__head">
        <p class="eyebrow">@Model.DirectionsEyebrow</p>
        <h2>@Model.DirectionsTitle</h2>
    </div>
    <div class="home-card-grid">
        @foreach (var card in Model.DirectionCards)
        {
            <a class="home-card" href="@card.Url">
                <h3>@card.Title</h3>
                <p>@card.Description</p>
            </a>
        }
    </div>
</section>

<section class="home-split">
    <div>
        <p class="eyebrow">@Model.ApproachEyebrow</p>
        <h2>@Model.ApproachTitle</h2>
        <p>
            @Model.ApproachDescription
        </p>
    </div>
    <div class="home-feature-list">
        @foreach (var feature in Model.Features)
        {
            <article>
                <h3>@feature.Title</h3>
                <p>@feature.Description</p>
            </article>
        }
    </div>
</section>

<section class="home-section home-section--white">
    <div class="home-section__head">
        <p class="eyebrow">Проекты и партнеры</p>
        <h2>Что нужно добавить в витрину сайта</h2>
    </div>
    <div class="home-showcase-grid">
        <article>
            <img src="@Model.HeroImageUrl" alt="Проект Comfort Rooms">
            <h3>Примеры объектов</h3>
            <p>На первоисточнике есть блок проектов. В новой версии он подготовлен как отдельная зона для будущих кейсов и изображений из админки.</p>
        </article>
        <article>
            <img src="@Model.HeroImageUrl" alt="Партнерская витрина Comfort Rooms">
            <h3>Партнерские материалы</h3>
            <p>Каталоги, остатки, фиды, логотипы и маркетинговые материалы должны стать управляемыми ссылками.</p>
        </article>
        <article>
            <img src="@Model.HeroImageUrl" alt="Отзывы клиентов Comfort Rooms">
            <h3>Отзывы клиентов</h3>
            <p>Отзывы и подтверждение опыта вынесены в структуру страницы, чтобы позже подключить управление через админку.</p>
        </article>
    </div>
</section>

<section class="home-cta">
    <p class="eyebrow">@Model.CtaEyebrow</p>
    <h2>@Model.CtaTitle</h2>
    <p>@Model.CtaDescription</p>
    <a class="button @Model.CtaButtonStyleClass" href="/sotrudnichestvo/na-zakaz#contact">@Model.CtaButtonText</a>
</section>
