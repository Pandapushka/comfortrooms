@model HomePageViewModel
@{
    ViewData["Title"] = "Главная";
}

<div class="home-page @Model.PageBackgroundClass">
<section class="hero-section home-hero @Model.HeroBackgroundClass">
    <div class="hero-section__content">
        <p class="eyebrow @Model.HeroEyebrowColorClass">@Model.HeroEyebrow</p>
        <h1 class="@Model.HeroTitleColorClass">@Model.HeroTitle</h1>
        <p class="@Model.HeroDescriptionColorClass">@Model.HeroDescription</p>
        <div class="simple-hero__actions">
            <a class="button @Model.HeroPrimaryButtonStyleClass" href="/sotrudnichestvo/na-zakaz">@Model.HeroPrimaryButtonText</a>
            <a class="button @Model.HeroSecondaryButtonStyleClass" href="/kontakty">@Model.HeroSecondaryButtonText</a>
        </div>
    </div>
    <div class="home-hero__media" aria-hidden="true">
        <img src="@Model.HeroImageUrl" alt="@Model.HeroImageAlt">
    </div>
</section>

<section class="home-section home-section--white @Model.StatsBackgroundClass">
    <div class="home-section__head">
        <p class="eyebrow @Model.StatsEyebrowColorClass">@Model.StatsEyebrow</p>
        <h2 class="@Model.StatsTitleColorClass">@Model.StatsTitle</h2>
    </div>
    <div class="home-stats-grid">
        @foreach (var stat in Model.Stats)
        {
            <article><strong>@stat.Value</strong><span>@stat.Description</span></article>
        }
    </div>
</section>

<section class="home-section home-section--white @Model.DirectionsBackgroundClass">
    <div class="home-section__head">
        <p class="eyebrow @Model.DirectionsEyebrowColorClass">@Model.DirectionsEyebrow</p>
        <h2 class="@Model.DirectionsTitleColorClass">@Model.DirectionsTitle</h2>
    </div>
    <div class="home-card-grid">
        @foreach (var card in Model.DirectionCards)
        {
            <a class="home-card" href="@card.Url">
                <h3>@card.Title</h3>
                <p>@card.Description</p>
            </a>
        }
    </div>
</section>

<section class="home-split @Model.ApproachBackgroundClass">
    <div>
        <p class="eyebrow @Model.ApproachEyebrowColorClass">@Model.ApproachEyebrow</p>
        <h2 class="@Model.ApproachTitleColorClass">@Model.ApproachTitle</h2>
        <p class="@Model.ApproachDescriptionColorClass">
            @Model.ApproachDescription
        </p>
    </div>
    <div class="home-feature-list">
        @foreach (var feature in Model.Features)
        {
            <article>
                <h3>@feature.Title</h3>
                <p>@feature.Description</p>
            </article>
        }
    </div>
</section>

<section class="home-cta @Model.CtaBackgroundClass">
    <p class="eyebrow @Model.CtaEyebrowColorClass">@Model.CtaEyebrow</p>
    <h2 class="@Model.CtaTitleColorClass">@Model.CtaTitle</h2>
    <p class="@Model.CtaDescriptionColorClass">@Model.CtaDescription</p>
    <a class="button @Model.CtaButtonStyleClass" href="/sotrudnichestvo/na-zakaz#contact">@Model.CtaButtonText</a>
</section>

@foreach (var section in Model.CustomSections)
{
    <partial name="_PageSection" model="section" />
}
</div>
