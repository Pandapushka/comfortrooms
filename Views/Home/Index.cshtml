@{
    ViewData["Title"] = "Главная";
    var textBlocks = ViewData["TextBlocks"] as IReadOnlyDictionary<string, string> ?? new Dictionary<string, string>();
    string Text(string key, string fallback) => textBlocks.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value) ? value : fallback;
    var heroTitle = ViewData["HeroTitle"] as string ?? "Свет, который становится частью архитектуры";
    var heroDescription = ViewData["HeroDescription"] as string ?? "Comfort Rooms создает выразительные световые решения для частных интерьеров, дизайнерских проектов, салонов и онлайн-партнеров.";
}

<section class="hero-section home-hero">
    <div class="hero-section__content">
        <p class="eyebrow">Премиальный свет для интерьеров</p>
        <h1>@heroTitle</h1>
        <p>@heroDescription</p>
        <div class="simple-hero__actions">
            <a class="button button--primary" href="/sotrudnichestvo/na-zakaz">Изготовление под заказ</a>
            <a class="button button--secondary" href="/kontakty">Связаться</a>
        </div>
    </div>
    <div class="home-hero__media" aria-hidden="true">
        <img src="https://image.qwenlm.ai/public_source/0292984e-e4f3-4e94-9aaf-0ce408d282fe/109d82bb8-7d01-4b67-9aa3-2b000e635158.png" alt="">
    </div>
</section>

<section class="home-section home-section--white">
    <div class="home-section__head">
        <p class="eyebrow">Направления</p>
        <h2>@Text("directions-title", "Основные разделы сайта")</h2>
    </div>
    <div class="home-card-grid">
        <a class="home-card" href="/sotrudnichestvo/na-zakaz">
            <span>01</span>
            <h3>Люстры под заказ</h3>
            <p>Индивидуальные светильники по чертежам, фото, эскизам и дизайнерским задачам.</p>
        </a>
        <a class="home-card" href="/sotrudnichestvo/dizayneram">
            <span>02</span>
            <h3>Дизайнерам</h3>
            <p>Партнерство для интерьерных проектов, комплектации объектов и авторских изделий.</p>
        </a>
        <a class="home-card" href="/sotrudnichestvo/magazinam">
            <span>03</span>
            <h3>Магазинам</h3>
            <p>Структура для салонов света, розничных партнеров и демонстрационных коллекций.</p>
        </a>
        <a class="home-card" href="/sotrudnichestvo/internet-magazinam">
            <span>04</span>
            <h3>Интернет-магазинам</h3>
            <p>Контентная и коммерческая база для будущего e-commerce сотрудничества.</p>
        </a>
    </div>
</section>

<section class="home-split">
    <div>
        <p class="eyebrow">Подход</p>
        <h2>@Text("approach-title", "Единый стиль для всех страниц")</h2>
        <p>
            @Text("approach-description", "Визуальная система строится вокруг готовой страницы «Изготовление люстр под заказ»: светлый фон, золотые акценты, крупная типографика, аккуратные карточки, галереи и спокойные анимации.")
        </p>
    </div>
    <div class="home-feature-list">
        <article>
            <h3>Галереи из админки</h3>
            <p>Изображения страниц хранятся в базе и управляются отдельно по разделам.</p>
        </article>
        <article>
            <h3>Заявки сохраняются</h3>
            <p>Форма на странице «под заказ» уже пишет обращения в SQLite.</p>
        </article>
        <article>
            <h3>Готово к расширению</h3>
            <p>Сервисы хранения изображений сразу разделены под будущий переход на S3.</p>
        </article>
    </div>
</section>

<section class="home-cta">
    <p class="eyebrow">Проектирование света</p>
    <h2>@Text("cta-title", "Нужен светильник под конкретный интерьер?")</h2>
    <p>@Text("cta-description", "Оставьте заявку на расчет индивидуального изделия или перейдите к странице с подробным процессом работы.")</p>
    <a class="button button--primary" href="/sotrudnichestvo/na-zakaz#contact">Оставить заявку</a>
</section>
