@{
    ViewData["Title"] = "О компании";
    var textBlocks = ViewData["TextBlocks"] as IReadOnlyDictionary<string, string> ?? new Dictionary<string, string>();
    string Text(string key, string fallback) => textBlocks.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value) ? value : fallback;
    var heroTitle = ViewData["HeroTitle"] as string ?? "О компании";
    var heroDescription = ViewData["HeroDescription"] as string ?? "Comfort Rooms работает со светом как с архитектурным акцентом: помогает подобрать готовые решения, спроектировать индивидуальные изделия и поддержать интерьерные проекты на всех этапах.";
    var heroImageUrl = ViewData["HeroImageUrl"] as string ?? "/images/fallbacks/luxury-chandelier-interior.png";
    var heroImageAlt = ViewData["HeroImageAlt"] as string ?? "Интерьерная люстра Comfort Rooms";
}

<section class="about-hero">
    <div>
        <p class="eyebrow">Comfort Rooms</p>
        <h1>@heroTitle</h1>
        <p>@heroDescription</p>
        <div class="simple-hero__accent">
            @Text("hero-accent", "Светильник должен не просто освещать пространство, а собирать интерьер в единую композицию.")
        </div>
    </div>
    <div class="about-hero__image">
        <img src="@heroImageUrl" alt="@heroImageAlt">
    </div>
</section>

<section class="about-section about-section--white">
    <div class="about-section__head">
        <p class="eyebrow">Принципы</p>
        <h2>@Text("principles-title", "Что важно в нашей работе")</h2>
    </div>
    <div class="about-values">
        <article>
            <span>01</span>
            <h3>Эстетика</h3>
            <p>Подбираем форму, масштаб и отделку так, чтобы светильник работал с интерьером, а не спорил с ним.</p>
        </article>
        <article>
            <span>02</span>
            <h3>Инженерия</h3>
            <p>Учитываем конструкцию, монтаж, материалы, покрытие и дальнейшую эксплуатацию изделия.</p>
        </article>
        <article>
            <span>03</span>
            <h3>Партнерство</h3>
            <p>Работаем с дизайнерами, магазинами и частными заказчиками прозрачно, с понятными сроками и этапами.</p>
        </article>
    </div>
</section>

<section class="about-process">
    <div>
        <p class="eyebrow">Процесс</p>
        <h2>@Text("process-title", "От идеи до готового светильника")</h2>
        <p>
            @Text("process-description", "Для нестандартных задач мы начинаем с эскиза, референса или чертежа, затем уточняем материалы, размеры, отделку и способ монтажа.")
        </p>
    </div>
    <ol>
        <li><span>Задача</span>Получаем вводные, фото, чертежи или описание объекта.</li>
        <li><span>Расчет</span>Готовим техническое решение и ориентир по стоимости.</li>
        <li><span>Производство</span>Согласовываем детали и передаем изделие в работу.</li>
        <li><span>Монтаж</span>Помогаем довести светильник до финального результата в интерьере.</li>
    </ol>
</section>

<section class="about-cta">
    <p class="eyebrow">Сотрудничество</p>
    <h2>@Text("cta-title", "Обсудим проект или партнерство?")</h2>
    <p>@Text("cta-description", "Перейдите к странице изготовления под заказ или оставьте заявку через контакты.")</p>
    <div class="simple-hero__actions">
        <a class="button button--primary" href="/sotrudnichestvo/na-zakaz">Изготовление под заказ</a>
        <a class="button button--secondary" href="/kontakty">Контакты</a>
    </div>
</section>
