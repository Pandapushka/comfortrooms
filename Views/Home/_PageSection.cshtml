@model PageSectionViewModel

@if (string.Equals(Model.TemplateKey, "cards-grid", StringComparison.OrdinalIgnoreCase))
{
    <section class="builder-cards @Model.BackgroundClass">
        <div class="builder-cards__head">
            @if (!string.IsNullOrWhiteSpace(Model.Eyebrow))
            {
                <p class="eyebrow @Model.EyebrowColorClass">@Model.Eyebrow</p>
            }
            <h2 class="@Model.TitleColorClass">@Model.Title</h2>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="@Model.DescriptionColorClass">@Model.Description</p>
            }
        </div>
        @if (Model.Cards.Count > 0)
        {
            <div class="builder-cards__grid">
                @foreach (var card in Model.Cards)
                {
                    if (card.IsLink)
                    {
                        <a class="builder-card builder-card--link" href="@(string.IsNullOrWhiteSpace(card.Url) ? "/" : card.Url)">
                            <h3>@card.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(card.Description))
                            {
                                <p>@card.Description</p>
                            }
                        </a>
                    }
                    else
                    {
                        <article class="builder-card">
                            <h3>@card.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(card.Description))
                            {
                                <p>@card.Description</p>
                            }
                        </article>
                    }
                }
            </div>
        }
    </section>
}
else if (string.Equals(Model.TemplateKey, "testimonials", StringComparison.OrdinalIgnoreCase))
{
    var hasCarousel = Model.Testimonials.Count > 3;

    <section class="home-section home-section--white @Model.BackgroundClass">
        <div class="home-section__head">
            @if (!string.IsNullOrWhiteSpace(Model.Eyebrow))
            {
                <p class="eyebrow @Model.EyebrowColorClass">@Model.Eyebrow</p>
            }
            <h2 class="@Model.TitleColorClass">@Model.Title</h2>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="@Model.DescriptionColorClass">@Model.Description</p>
            }
        </div>
        @if (hasCarousel)
        {
            <div class="home-testimonials home-testimonials--carousel" data-home-testimonials>
                <button class="home-carousel-button home-carousel-button--prev" type="button" data-home-testimonials-prev aria-label="Предыдущий отзыв">‹</button>
                <div class="home-testimonials__viewport">
                    <div class="home-testimonials__track" data-home-testimonials-track>
                        @foreach (var testimonial in Model.Testimonials)
                        {
                            <article class="home-testimonial-card">
                                <img src="@testimonial.ImageUrl" alt="@(testimonial.AltText ?? testimonial.Title)">
                                <div>
                                    <h3>@testimonial.Title</h3>
                                    <p>@testimonial.Text</p>
                                    @if (!string.IsNullOrWhiteSpace(testimonial.Author))
                                    {
                                        <span>@testimonial.Author</span>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </div>
                <button class="home-carousel-button home-carousel-button--next" type="button" data-home-testimonials-next aria-label="Следующий отзыв">›</button>
                <div class="home-carousel-dots" data-home-testimonials-dots>
                    @for (var index = 0; index < Model.Testimonials.Count; index++)
                    {
                        <button class="home-carousel-dot @(index == 0 ? "is-active" : "")" type="button" data-index="@index" aria-label="Группа отзывов @(index + 1)"></button>
                    }
                </div>
            </div>
        }
        else if (Model.Testimonials.Count > 0)
        {
            <div class="home-testimonials home-testimonials--static">
                @foreach (var testimonial in Model.Testimonials)
                {
                    <article class="home-testimonial-card">
                        <img src="@testimonial.ImageUrl" alt="@(testimonial.AltText ?? testimonial.Title)">
                        <div>
                            <h3>@testimonial.Title</h3>
                            <p>@testimonial.Text</p>
                            @if (!string.IsNullOrWhiteSpace(testimonial.Author))
                            {
                                <span>@testimonial.Author</span>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>
}
else if (string.Equals(Model.TemplateKey, "map", StringComparison.OrdinalIgnoreCase))
{
    <section class="builder-map @Model.BackgroundClass">
        <div class="builder-map__frame">
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                @Html.Raw(Model.Description)
            }
            else
            {
                <div class="builder-map__empty">Код карты пока не добавлен.</div>
            }
        </div>
    </section>
}
else if (string.Equals(Model.TemplateKey, "portfolio", StringComparison.OrdinalIgnoreCase))
{
    <section class="builder-portfolio @Model.BackgroundClass">
        <div class="builder-portfolio__head">
            @if (!string.IsNullOrWhiteSpace(Model.Eyebrow))
            {
                <p class="eyebrow @Model.EyebrowColorClass">@Model.Eyebrow</p>
            }
            <h2 class="@Model.TitleColorClass">@Model.Title</h2>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="@Model.DescriptionColorClass">@Model.Description</p>
            }
        </div>

        @if (Model.PortfolioImages.Count > 0)
        {
            <div class="builder-portfolio-carousel" data-portfolio-carousel>
                <button class="builder-portfolio-carousel__button builder-portfolio-carousel__button--prev" type="button" data-portfolio-prev aria-label="Предыдущий слайд">‹</button>
                <div class="builder-portfolio-carousel__viewport">
                    <div class="builder-portfolio-carousel__track" data-portfolio-track>
                        @foreach (var image in Model.PortfolioImages)
                        {
                            <div class="builder-portfolio-slide">
                                <img src="@image.ImageUrl" alt="@(image.AltText ?? image.Title)">
                                <span>@image.Title</span>
                            </div>
                        }
                    </div>
                </div>
                <button class="builder-portfolio-carousel__button builder-portfolio-carousel__button--next" type="button" data-portfolio-next aria-label="Следующий слайд">›</button>
            </div>

            <div class="builder-portfolio-dots" data-portfolio-dots>
                @for (var index = 0; index < Model.PortfolioImages.Count; index++)
                {
                    <button class="builder-portfolio-dot @(index == 0 ? "is-active" : "")" data-index="@index" type="button" aria-label="Слайд @(index + 1)"></button>
                }
            </div>
        }
    </section>
}
else
{
    <section class="builder-section builder-section--@Model.LayoutKey @Model.BackgroundClass">
        <div class="builder-section__content">
            @if (!string.IsNullOrWhiteSpace(Model.Eyebrow))
            {
                <p class="eyebrow @Model.EyebrowColorClass">@Model.Eyebrow</p>
            }
            <h2 class="@Model.TitleColorClass">@Model.Title</h2>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="@Model.DescriptionColorClass">@Model.Description</p>
            }
            @if (Model.Buttons.Count > 0)
            {
                <div class="builder-section__actions">
                    @foreach (var button in Model.Buttons)
                    {
                        <a class="button @button.StyleClass" href="@button.Url">@button.Text</a>
                    }
                </div>
            }
        </div>
        <div class="builder-section__media" aria-hidden="@(string.IsNullOrWhiteSpace(Model.ImageAltText) ? "true" : "false")">
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.ImageAltText">
            }
            else
            {
                <div class="builder-section__placeholder"></div>
            }
        </div>
    </section>
}
